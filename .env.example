# Oura API credentials
# OAuth2 is the recommended authentication method (PATs were deprecated Dec 2025).
#
# Setup: Go to https://cloud.ouraring.com and navigate to 'My Applications'
#        Then run: python api/oura_oauth2_setup.py
#
# Legacy PAT support is still available if you have an existing token.

# OAuth2 (recommended)
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
