# Oura API credentials (OAuth2)
#
# Setup instructions:
#   1. Go to https://cloud.ouraring.com and sign in
#   2. Navigate to 'My Applications' in the developer portal
#   3. Create a new application:
#      - App name: Oura Digital Twin (or any name)
#      - Redirect URI: http://localhost:4421/callback
#   4. Copy the Client ID and Client Secret below
#   5. Run: python api/oura_oauth2_setup.py
#      This opens a browser for authorization and saves tokens automatically.
#
# After setup, import_oura.py will use these tokens.
# The refresh token is rotated automatically by the daily pipeline.

# OAuth2 credentials (required)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# OAuth2 tokens (populated by oura_oauth2_setup.py - do not edit manually)
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=
