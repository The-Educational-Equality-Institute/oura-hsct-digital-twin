# Oura API credentials
# Two authentication methods are supported:
#
# Option A: Personal Access Token (simplest)
#   Get yours at https://cloud.ouraring.com/personal-access-tokens
#   OURA_ACCESS_TOKEN=your_pat_here
#
# Option B: OAuth2 (for multi-user / refresh flow)
#   Register at https://cloud.ouraring.com/v2/docs
#   Then run: python api/oura_oauth2_setup.py

# Required (at least one)
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=

# OAuth2 only
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
